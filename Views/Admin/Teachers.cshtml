@model List<Teacher>
@{
    ViewData["Title"] = "Enseignants";
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold"><i class="fas fa-chalkboard-teacher me-2 text-primary"></i>Enseignants</h4>
            <p class="text-muted small mb-0">Gestion des comptes enseignants</p>
        </div>
        <a href="@Url.Action("CreateTeacher")" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Nouvel enseignant</a>
    </div>
    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover" id="teachersTable">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Email</th>
                        <th>Département</th>
                        <th>Matičres</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var teacher in Model)
                    {
                        var initials = FileHelper.GetInitials(teacher.User.FirstName, teacher.User.LastName);
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(teacher.User.ProfilePicturePath))
                                    {
                                        <img src="@teacher.User.ProfilePicturePath" class="avatar-sm rounded-circle" />
                                    }
                                    else
                                    {
                                        <div class="avatar-sm avatar-initials">@initials</div>
                                    }
                                    <span class="fw-semibold">@teacher.User.FirstName @teacher.User.LastName</span>
                                </div>
                            </td>
                            <td class="text-muted">@teacher.User.Email</td>
                            <td>@(teacher.Department ?? "—")</td>
                            <td><span class="badge bg-primary-subtle text-primary">@teacher.Subjects.Count matičre(s)</span></td>
                            <td>
                                <a href="@Url.Action("EditUser", new { id = teacher.User.Id })" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit me-1"></i>Modifier</a>
                                <form asp-action="DeleteTeacher" method="post" class="d-inline delete-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@teacher.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger delete-btn"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script>$(document).ready(function() { $('#teachersTable').DataTable({ language: { url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/fr-FR.json' } }); });</script>
}
