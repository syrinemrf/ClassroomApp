@model ClassroomApp.Models.ViewModels.Admin.CreateSubjectViewModel
@{
    ViewData["Title"] = "Nouvelle matičre";
}
<div class="container-fluid">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="@Url.Action("Subjects")" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left"></i></a>
        <h4 class="mb-0 fw-bold"><i class="fas fa-plus me-2 text-primary"></i>Nouvelle matičre</h4>
    </div>
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="CreateSubject" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row mb-4">
                            <div class="col-md-8">
                                <label asp-for="Name" class="form-label fw-semibold">Nom de la matičre <span class="text-danger">*</span></label>
                                <input asp-for="Name" class="form-control form-control-lg" placeholder="ex: Mathématiques, Informatique..." />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Color" class="form-label fw-semibold">Couleur <span class="text-danger">*</span></label>
                                <div class="d-flex align-items-center gap-2">
                                    <input asp-for="Color" type="color" class="form-control form-control-color" style="width:60px;height:42px" />
                                    <span class="text-muted small">Visible dans le calendrier</span>
                                </div>
                                <span asp-validation-for="Color" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="Description optionnelle..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TeacherId" class="form-label fw-semibold">Enseignant responsable <span class="text-danger">*</span></label>
                            <select asp-for="TeacherId" class="form-select form-select-lg">
                                <option value="">— Sélectionner un enseignant —</option>
                                @if (Model.AvailableTeachers != null)
                                {
                                    @foreach (var t in Model.AvailableTeachers)
                                    {
                                        <option value="@t.Key">@t.Value</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="TeacherId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Classes concernées <span class="text-danger">*</span></label>
                            <p class="text-muted small mb-2">Cochez toutes les classes qui suivront cette matičre.</p>
                            <div class="row g-2">
                                @if (Model.AvailableClassrooms != null)
                                {
                                    @foreach (var c in Model.AvailableClassrooms)
                                    {
                                        <div class="col-md-4 col-sm-6">
                                            <label class="classroom-check-label w-100" for="cls_@c.Key">
                                                <input type="checkbox" name="ClassroomIds" value="@c.Key" id="cls_@c.Key" class="classroom-check-input" />
                                                <span class="classroom-check-box">
                                                    <i class="fas fa-users me-2"></i>@c.Value
                                                </span>
                                            </label>
                                        </div>
                                    }
                                }
                            </div>
                            <span asp-validation-for="ClassroomIds" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="d-flex gap-2 pt-2">
                            <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-2"></i>Créer la matičre</button>
                            <a href="@Url.Action("Subjects")" class="btn btn-outline-secondary">Annuler</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
