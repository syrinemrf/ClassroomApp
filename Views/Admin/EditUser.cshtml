@model ClassroomApp.Models.ViewModels.Admin.EditUserViewModel
@using ClassroomApp.Models.Enums
@{
    ViewData["Title"] = "Modifier l'utilisateur";
    var roleLabel = Model.Role == Role.Admin ? "Administrateur" : Model.Role == Role.Teacher ? "Enseignant" : "Étudiant";
    var roleBadge = Model.Role == Role.Admin ? "bg-danger-subtle text-danger" : Model.Role == Role.Teacher ? "bg-primary-subtle text-primary" : "bg-success-subtle text-success";
}
<div class="container-fluid">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="@(Model.Role == Role.Teacher ? Url.Action("Teachers") : Model.Role == Role.Student ? Url.Action("Students") : Url.Action("Dashboard"))" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h4 class="mb-0"><i class="fas fa-user-edit me-2"></i>Modifier le profil</h4>
        <span class="badge @roleBadge">@roleLabel</span>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white"><h6 class="mb-0 fw-bold"><i class="fas fa-id-card me-2 text-primary"></i>Informations personnelles</h6></div>
                <div class="card-body">
                    <form asp-action="EditUser" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Role" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label fw-semibold">Prénom</label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label fw-semibold">Nom</label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label fw-semibold">Compte actif</label>
                            </div>
                        </div>

                        @if (Model.Role == Role.Teacher)
                        {
                            <div class="mb-3">
                                <label asp-for="Department" class="form-label fw-semibold">Département</label>
                                <input asp-for="Department" class="form-control" />
                            </div>
                            <div class="mb-3">
                                <label asp-for="Bio" class="form-label fw-semibold">Biographie</label>
                                <textarea asp-for="Bio" class="form-control" rows="3"></textarea>
                            </div>
                        }

                        @if (Model.Role == Role.Student && Model.AvailableClassrooms != null)
                        {
                            <div class="mb-3">
                                <label asp-for="ClassroomId" class="form-label fw-semibold">Classe</label>
                                <select asp-for="ClassroomId" class="form-select">
                                    <option value="">Sélectionner une classe...</option>
                                    @foreach (var c in Model.AvailableClassrooms)
                                    {
                                        <option value="@c.Key" selected="@(Model.ClassroomId == c.Key)">@c.Value</option>
                                    }
                                </select>
                            </div>
                        }

                        <hr class="my-4" />
                        <h6 class="fw-bold mb-3"><i class="fas fa-lock me-2 text-warning"></i>Changer le mot de passe</h6>
                        <p class="text-muted small mb-3">Laissez vide pour conserver le mot de passe actuel.</p>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="NewPassword" class="form-label fw-semibold">Nouveau mot de passe</label>
                                <input asp-for="NewPassword" class="form-control" type="password" autocomplete="new-password" />
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirmer</label>
                                <input asp-for="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-2"></i>Enregistrer</button>
                            <a href="@(Model.Role == Role.Teacher ? Url.Action("Teachers") : Model.Role == Role.Student ? Url.Action("Students") : Url.Action("Dashboard"))" class="btn btn-outline-secondary">Annuler</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
