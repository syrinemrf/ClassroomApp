@model List<ClassroomApp.Models.ViewModels.Subject.SubjectCardViewModel>
@{
    ViewData["Title"] = "Mes matieres";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold">
            <i class="fas fa-th-large me-2" style="color:#166534"></i>Mes matieres
        </h4>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-book fa-3x text-muted mb-3"></i>
            <h5 class="text-muted">Aucune matiere disponible</h5>
            <p class="text-muted small">Vos matieres apparaitront ici une fois que vous serez inscrit dans une classe.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var card in Model)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="gc-card card border-0 shadow-sm h-100">
                        <a href="@Url.Action("Details", "Subject", new { id = card.SubjectId })" class="text-decoration-none">
                            <div class="gc-card-header" style="background: @card.Color;">
                                <div class="gc-card-subject-name">@card.SubjectName</div>
                                <div class="gc-card-classrooms">@card.TeacherName</div>
                                <div class="gc-card-avatar">
                                    @if (!string.IsNullOrEmpty(card.TeacherProfilePicture))
                                    {
                                        <img src="@card.TeacherProfilePicture" alt="@card.TeacherName" />
                                    }
                                    else
                                    {
                                        <div class="gc-avatar-initials">@card.TeacherInitials</div>
                                    }
                                </div>
                            </div>
                            <div class="gc-card-body">
                                <div class="gc-card-stats">
                                    <span class="gc-stat">
                                        <i class="fas fa-book"></i> @card.CourseCount cours
                                    </span>
                                    @if (card.PendingAssignments > 0)
                                    {
                                        <span class="gc-stat text-danger fw-bold">
                                            <i class="fas fa-clock"></i> @card.PendingAssignments a rendre
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="gc-stat text-success">
                                            <i class="fas fa-check-circle"></i> A jour
                                        </span>
                                    }
                                </div>
                            </div>
                        </a>
                        <div class="gc-card-footer">
                            <a href="@Url.Action("Details", "Subject", new { id = card.SubjectId, tab = "stream" })" class="gc-card-action" title="Stream">
                                <i class="fas fa-stream"></i>
                            </a>
                            <a href="@Url.Action("Details", "Subject", new { id = card.SubjectId, tab = "classwork" })" class="gc-card-action" title="Travaux">
                                <i class="fas fa-folder-open"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>