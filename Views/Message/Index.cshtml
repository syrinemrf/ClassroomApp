@model ConversationViewModel
@{
    ViewData["Title"] = "Messages";
}
<div class="container-fluid">
    <h4 class="mb-4"><i class="fas fa-envelope me-2"></i>Messages</h4>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="row g-0" style="min-height: 500px;">
                <!-- Conversations list -->
                <div class="col-md-4 border-end">
                    <div class="p-3 border-bottom"><input type="text" class="form-control form-control-sm" placeholder="Search conversations..." id="searchConversations" /></div>
                    <div class="conversation-list" style="max-height: 450px; overflow-y: auto;">
                        @foreach (var conv in Model.Conversations)
                        {
                            var isActive = Model.ActiveUserId == conv.UserId;
                            <a href="@Url.Action("Index", new { userId = conv.UserId })" class="d-flex align-items-center gap-2 p-3 text-decoration-none text-dark border-bottom conversation-item @(isActive ? "bg-primary-subtle" : "")">
                                <div class="avatar-sm avatar-initials">@conv.UserName[0]</div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="d-flex justify-content-between">
                                        <strong class="small">@conv.UserName</strong>
                                        @if (conv.UnreadCount > 0)
                                        {
                                            <span class="badge bg-danger rounded-pill">@conv.UnreadCount</span>
                                        }
                                    </div>
                                    <small class="text-muted text-truncate d-block">@(conv.LastMessage ?? "No messages yet")</small>
                                </div>
                            </a>
                        }
                    </div>
                </div>

                <!-- Chat window -->
                <div class="col-md-8">
                    @if (Model.ActiveUserId.HasValue)
                    {
                        <div class="p-3 border-bottom d-flex align-items-center gap-2">
                            <div class="avatar-sm avatar-initials">@(Model.ActiveUserName?[0])</div>
                            <strong>@Model.ActiveUserName</strong>
                        </div>
                        <div class="chat-messages p-3" style="height: 380px; overflow-y: auto;" id="chatMessages">
                            @foreach (var msg in Model.Messages)
                            {
                                <div class="d-flex mb-3 @(msg.IsFromCurrentUser ? "justify-content-end" : "")">
                                    <div class="chat-bubble @(msg.IsFromCurrentUser ? "chat-sent" : "chat-received")">
                                        <p class="mb-1">@msg.Content</p>
                                        <small class="text-muted" style="font-size:0.7rem">@msg.SentAt.ToString("HH:mm")</small>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="p-3 border-top">
                            <form asp-action="Send" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="receiverId" value="@Model.ActiveUserId" />
                                <div class="input-group">
                                    <input type="text" name="content" class="form-control" placeholder="Type a message..." required autofocus />
                                    <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i></button>
                                </div>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                            <i class="fas fa-comments fa-3x mb-3"></i>
                            <p>Select a conversation to start messaging</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        var chatBox = document.getElementById('chatMessages');
        if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
        $('#searchConversations').on('input', function() {
            var q = $(this).val().toLowerCase();
            $('.conversation-item').each(function() { $(this).toggle($(this).text().toLowerCase().includes(q)); });
        });
    </script>
}
