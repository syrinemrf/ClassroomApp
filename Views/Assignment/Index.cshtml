@model List<AssignmentViewModel>
@{
    ViewData["Title"] = "Assignments";
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0"><i class="fas fa-file-alt me-2"></i>My Assignments</h4>
        <a href="@Url.Action("Create")" class="btn btn-primary"><i class="fas fa-plus me-2"></i>New Assignment</a>
    </div>
    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover" id="assignmentsTable">
                <thead>
                    <tr><th>Title</th><th>Classroom</th><th>Deadline</th><th>Max Score</th><th>Submissions</th><th>Status</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td class="fw-bold">@a.Title</td>
                            <td>@a.ClassroomName</td>
                            <td>@a.Deadline.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>@a.MaxScore</td>
                            <td>@a.SubmissionCount / @a.TotalStudents</td>
                            <td><span class="badge @a.DeadlineBadgeClass">@a.DeadlineStatus</span></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="@Url.Action("Details", new { id = a.Id })" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a>
                                    <a href="@Url.Action("Edit", new { id = a.Id })" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                                    <form asp-action="Delete" method="post" class="d-inline delete-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@a.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger delete-btn"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script>$(document).ready(function() { $('#assignmentsTable').DataTable({ pageLength: 10, order: [[2, 'desc']] }); });</script>
}
