@model AssignmentViewModel
@{
    ViewData["Title"] = Model.Title;
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0"><i class="fas fa-file-alt me-2"></i>@Model.Title</h4>
        <span class="badge @Model.DeadlineBadgeClass fs-6">@Model.DeadlineStatus</span>
    </div>
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <p>@Model.Description</p>
                    <div class="row text-muted small">
                        <div class="col-md-4"><i class="fas fa-school me-1"></i>@Model.ClassroomName</div>
                        <div class="col-md-4"><i class="fas fa-calendar me-1"></i>Deadline: @Model.Deadline.ToString("MMM dd, yyyy HH:mm")</div>
                        <div class="col-md-4"><i class="fas fa-star me-1"></i>Max Score: @Model.MaxScore</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h5 class="fw-bold">@Model.SubmissionCount / @Model.TotalStudents</h5>
                    <small class="text-muted">Submissions</small>
                    <div class="progress mt-2" style="height:8px;">
                        @{ var pct = Model.TotalStudents > 0 ? (int)(Model.SubmissionCount * 100.0 / Model.TotalStudents) : 0; }
                        <div class="progress-bar bg-primary" style="width:@pct%"></div>
                    </div>
                    <small class="text-muted">@Model.GradedCount graded</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white"><h6 class="mb-0 fw-bold">Remises des étudiants</h6></div>
        <div class="card-body">
            <table class="table table-hover" id="submissionsTable">
                <thead><tr><th>Etudiant</th><th># Étudiant</th><th>Statut</th><th>Remis</th><th>Note</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var s in Model.Submissions)
                    {
                        var statusClass = s.Status switch
                        {
                            SubmissionStatus.Graded => "bg-success",
                            SubmissionStatus.Submitted => "bg-primary",
                            SubmissionStatus.Late => "bg-warning text-dark",
                            SubmissionStatus.Pending => "bg-danger",
                            _ => "bg-secondary"
                        };
                        var statusText = s.Status switch
                        {
                            SubmissionStatus.Graded => "Noté",
                            SubmissionStatus.Submitted => "Remis",
                            SubmissionStatus.Late => "Remis tard",
                            SubmissionStatus.Pending => "Non remis",
                            _ => "En attente"
                        };
                        <tr>
                            <td>@s.StudentName</td>
                            <td><code>@s.StudentNumber</code></td>
                            <td><span class="badge @statusClass">@statusText</span></td>
                            <td>@(s.SubmittedAt?.ToString("dd MMM HH:mm") ?? "—")</td>
                            <td>@(s.Score.HasValue ? $"{s.Score}/{s.MaxScore}" : "—")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    @if (s.SubmissionId != Guid.Empty)
                                    {
                                        <a href="@Url.Action("Grade", "Submission", new { id = s.SubmissionId })" class="btn btn-sm btn-outline-primary" title="Noter cette remise"><i class="fas fa-pen"></i> Noter</a>
                                        @if (!string.IsNullOrEmpty(s.FileName))
                                        {
                                            <a href="@Url.Action("Download", "Submission", new { id = s.SubmissionId })" class="btn btn-sm btn-outline-info" title="Télécharger le fichier"><i class="fas fa-download"></i></a>
                                        }
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("GradeStudent", "Submission", new { assignmentId = Model.Id, studentId = s.StudentId })" class="btn btn-sm btn-outline-danger" title="Noter cet étudiant sans remise"><i class="fas fa-pen"></i> Noter</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @await Html.PartialAsync("_Comments", Model.Comments)
</div>
@section Scripts {
    <script>$(document).ready(function() { $('#submissionsTable').DataTable({ pageLength: 10 }); });</script>
}
