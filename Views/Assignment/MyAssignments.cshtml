@model List<AssignmentViewModel>
@{
    ViewData["Title"] = "My Assignments";
}
<div class="container-fluid">
    <h4 class="mb-4"><i class="fas fa-file-alt me-2"></i>My Assignments</h4>
    <div class="row g-4">
        @if (Model.Any())
        {
            @foreach (var a in Model)
            {
                var statusClass = a.MySubmissionStatus switch
                {
                    SubmissionStatus.Graded => "bg-success",
                    SubmissionStatus.Submitted => "bg-primary",
                    SubmissionStatus.Late => "bg-warning text-dark",
                    _ => "bg-secondary"
                };
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100 card-hover">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-bold mb-0">@a.Title</h6>
                                <span class="badge @a.DeadlineBadgeClass">@a.DeadlineStatus</span>
                            </div>
                            <p class="text-muted small mb-2">@a.ClassroomName � by @a.TeacherName</p>
                            <div class="small text-muted mb-2">
                                <i class="fas fa-calendar me-1"></i>@a.Deadline.ToString("MMM dd, yyyy HH:mm")
                                <br /><i class="fas fa-star me-1"></i>Max: @a.MaxScore pts
                            </div>
                            @if (a.MySubmissionStatus.HasValue)
                            {
                                <span class="badge @statusClass">@a.MySubmissionStatus</span>
                                @if (a.MyScore.HasValue)
                                {
                                    <span class="badge bg-info">@a.MyScore / @a.MaxScore</span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">Non remis</span>
                            }
                        </div>
                        <div class="card-footer bg-white">
                            <a href="@Url.Action("StudentDetails", new { id = a.Id })" class="btn btn-sm btn-outline-primary w-100"><i class="fas fa-eye me-2"></i>Voir le détail</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                <p class="text-muted">Aucun devoir disponible.</p>
            </div>
        }
    </div>
</div>
