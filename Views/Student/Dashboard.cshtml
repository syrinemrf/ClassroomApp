@using ClassroomApp.Models.Entities
@{
    ViewData["Title"] = "Tableau de bord";
    var studentName = ViewBag.StudentName as string;
    var profilePic = ViewBag.ProfilePicture as string;
    int courseCount = ViewBag.CourseCount;
    int pendingCount = ViewBag.PendingCount;
    int submittedCount = ViewBag.SubmittedCount;
    double avgGrade = ViewBag.AverageGrade;
    var upcomingDeadlines = ViewBag.UpcomingDeadlines as dynamic;
    var recentGrades = ViewBag.RecentGrades as List<Submission>;
}
<div class="container-fluid">
    <div class="card border-0 shadow-sm mb-4 overflow-hidden" style="background: linear-gradient(135deg, #059669, #0d9488);">
        <div class="card-body d-flex align-items-center gap-4 py-4 px-4">
            @if (!string.IsNullOrEmpty(profilePic))
            {
                <img src="@profilePic" class="avatar-lg rounded-circle" style="border:3px solid rgba(255,255,255,0.4)" />
            }
            else
            {
                <div class="avatar-lg avatar-initials" style="background:rgba(255,255,255,0.2);color:white;font-size:1.5rem;border:3px solid rgba(255,255,255,0.4)">@(studentName?[0])</div>
            }
            <div>
                <h4 class="fw-bold mb-1 text-white">Bonjour, @studentName !</h4>
                <p class="mb-0 text-white" style="opacity:0.85">Continue comme ca, tu fais du bon travail !</p>
            </div>
            <div class="ms-auto">
                <a href="@Url.Action("StudentIndex", "Subject")" class="btn btn-light fw-semibold">
                    <i class="fas fa-th-large me-2"></i>Mes matieres
                </a>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-info-subtle text-info"><i class="fas fa-book"></i></div>
                    <div><p class="text-muted small mb-0">Cours disponibles</p><h3 class="fw-bold mb-0">@courseCount</h3></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-warning-subtle text-warning"><i class="fas fa-clock"></i></div>
                    <div><p class="text-muted small mb-0">Devoirs a rendre</p><h3 class="fw-bold mb-0 @(pendingCount > 0 ? "text-warning" : "")">@pendingCount</h3></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-success-subtle text-success"><i class="fas fa-check-circle"></i></div>
                    <div><p class="text-muted small mb-0">Soumissions</p><h3 class="fw-bold mb-0">@submittedCount</h3></div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon bg-primary-subtle text-primary"><i class="fas fa-star"></i></div>
                    <div><p class="text-muted small mb-0">Moyenne generale</p><h3 class="fw-bold mb-0">@(avgGrade > 0 ? $"{avgGrade:F1}/20" : "N/A")</h3></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pb-0 pt-3 px-4">
                    <h6 class="fw-bold mb-0">Echeances proches <span class="badge bg-danger-subtle text-danger ms-1">7 jours</span></h6>
                </div>
                <div class="card-body p-0">
                    @if (upcomingDeadlines != null)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var a in upcomingDeadlines)
                            {
                                <a href="@Url.Action("StudentDetails", "Assignment", new { id = a.Id })" class="list-group-item list-group-item-action px-4 py-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="mb-0 fw-semibold">@a.Title</p>
                                            <small class="text-muted">@a.ClassroomName</small>
                                        </div>
                                        <span class="badge bg-danger-subtle text-danger-emphasis ms-2 flex-shrink-0">
                                            @a.Deadline.ToString("dd MMM HH:mm")
                                        </span>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-check-circle fa-2x mb-2 text-success"></i>
                            <p class="mb-0">Aucune echeance urgente</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pb-0 pt-3 px-4 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0">Dernieres notes</h6>
                    <a href="@Url.Action("MySubmissions", "Submission")" class="btn btn-sm btn-outline-success">Voir tout</a>
                </div>
                <div class="card-body p-0">
                    @if (recentGrades?.Any() == true)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var s in recentGrades)
                            {
                                <div class="list-group-item px-4 py-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <p class="mb-0 fw-semibold">@s.Assignment?.Title</p>
                                            <small class="text-muted">@s.Assignment?.Classroom?.Name</small>
                                        </div>
                                        @if (s.Score.HasValue)
                                        {
                                            <span class="badge bg-success-subtle text-success-emphasis fs-6">@s.Score / @s.Assignment?.MaxScore</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary-emphasis">Non note</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-star fa-2x mb-2"></i>
                            <p class="mb-0">Aucune note recente</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>