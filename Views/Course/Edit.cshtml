@model EditCourseViewModel
@{
    ViewData["Title"] = "Modifier le cours";
}
<div class="container-fluid">
    <h4 class="mb-4"><i class="fas fa-edit me-2"></i>Modifier le cours</h4>
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold">Titre</label>
                    <input asp-for="Title" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Fichier</label>
                        <input class="form-control" value="@Model.FileName" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Classes</label>
                        <input class="form-control" value="@string.Join(", ", Model.ClassroomNames)" disabled />
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Enregistrer</button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>
