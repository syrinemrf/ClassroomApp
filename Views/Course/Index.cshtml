@model List<CourseViewModel>
@{
    ViewData["Title"] = "Mes cours";
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0"><i class="fas fa-book me-2"></i>Mes cours</h4>
        <a href="@Url.Action("Create")" class="btn btn-primary"><i class="fas fa-upload me-2"></i>Ajouter un cours</a>
    </div>
    <div class="row g-4">
        @if (Model.Any())
        {
            @foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100 card-hover">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="fas @course.FileTypeIcon fa-2x"></i>
                                <div>
                                    <h6 class="fw-bold mb-0">@course.Title</h6>
                                    <div class="d-flex flex-wrap gap-1 mt-1">
                                        @foreach (var cls in course.ClassroomNames)
                                        {
                                            <span class="badge bg-primary-subtle text-primary" style="font-size:.7rem">@cls</span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <p class="text-muted small mb-2">@(course.Description ?? "Aucune description")</p>
                            <div class="d-flex justify-content-between align-items-center small text-muted">
                                <span><i class="fas fa-file me-1"></i>@course.FileName</span>
                                <span>@course.FileSizeFormatted</span>
                            </div>
                            <small class="text-muted">Mis en ligne le @course.CreatedAt.ToString("dd MMM yyyy")</small>
                        </div>
                        <div class="card-footer bg-white d-flex justify-content-end gap-2">
                            <a href="@Url.Action("Edit", new { id = course.Id })" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                            <a href="@Url.Action("Download", new { id = course.Id })" class="btn btn-sm btn-outline-info"><i class="fas fa-download"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@course.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger delete-btn"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-book fa-3x text-muted mb-3"></i>
                <p class="text-muted">Aucun cours mis en ligne.</p>
                <a href="@Url.Action("Create")" class="btn btn-primary"><i class="fas fa-upload me-2"></i>Ajouter le premier cours</a>
            </div>
        }
    </div>
</div>
