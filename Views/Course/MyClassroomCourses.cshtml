@model List<CourseViewModel>
@{
    ViewData["Title"] = "My Classroom Courses";
}
<div class="container-fluid">
    <h4 class="mb-4"><i class="fas fa-book me-2"></i>Classroom Courses</h4>
    <div class="row g-4">
        @if (Model.Any())
        {
            @foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100 card-hover">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="fas @course.FileTypeIcon fa-2x"></i>
                                <div>
                                    <h6 class="fw-bold mb-0">@course.Title</h6>
                                    <small class="text-muted">by @course.TeacherName</small>
                                </div>
                            </div>
                            <p class="text-muted small mb-2">@(course.Description ?? "No description")</p>
                            <div class="d-flex justify-content-between small text-muted mb-2">
                                <span>@course.FileName</span>
                                <span>@course.FileSizeFormatted</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <a href="@Url.Action("Download", new { id = course.Id })" class="btn btn-sm btn-primary w-100"><i class="fas fa-download me-2"></i>Download</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-book-open fa-3x text-muted mb-3"></i>
                <p class="text-muted">No courses available yet.</p>
            </div>
        }
    </div>
</div>
