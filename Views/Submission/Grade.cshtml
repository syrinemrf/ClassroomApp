@model GradeSubmissionViewModel
@{
    ViewData["Title"] = "Noter le devoir";
}
<div class="container-fluid">
    <h4 class="mb-4"><i class="fas fa-pen me-2"></i>Noter le devoir</h4>
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white"><h6 class="mb-0 fw-bold">Informations étudiant</h6></div>
                <div class="card-body">
                    <p><strong>@Model.StudentName</strong></p>
                    <p class="small text-muted">@Model.StudentNumber</p>
                    <hr />
                    <p class="small"><strong>Devoir :</strong> @Model.AssignmentTitle</p>
                    <p class="small"><strong>Statut :</strong> <span class="badge bg-info">@Model.Status</span></p>
                    <p class="small"><strong>Remis le :</strong> @(Model.SubmittedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</p>
                    @if (!string.IsNullOrEmpty(Model.FileName))
                    {
                        <a href="@Url.Action("Download", new { id = Model.SubmissionId })" class="btn btn-sm btn-outline-primary w-100">
                            <i class="fas fa-download me-2"></i>@Model.FileName
                        </a>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white"><h6 class="mb-0 fw-bold">Grade</h6></div>
                <div class="card-body">
                    <form asp-action="Grade" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="SubmissionId" />
                        <div class="mb-3">
                            <label asp-for="Score" class="form-label">Note (sur @Model.MaxScore)</label>
                            <input asp-for="Score" class="form-control form-control-lg" type="number" min="0" max="@Model.MaxScore" />
                            <span asp-validation-for="Score" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="TeacherComment" class="form-label">Commentaire (optionnel)</label>
                            <textarea asp-for="TeacherComment" class="form-control" rows="4" placeholder="Feedback pour l'étudiant..."></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save me-2"></i>Enregistrer la note</button>
                            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg">Annuler</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
